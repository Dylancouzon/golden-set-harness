QDRANT_URL=
QDRANT_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

QDRANT_COLLECTION=fiqa_eval
DENSE_MODEL=text-embedding-3-small
DENSE_DIM=1536
SPARSE_MODEL=Qdrant/bm25
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
GENERATOR_MODEL=claude-sonnet-4-6
JUDGE_MODEL=gpt-5.4

EVAL_SAMPLE_SIZE=300
RANDOM_SEED=42
TOP_K_RETRIEVE=50
TOP_K_RERANK=10

# HNSW knobs (Qdrant defaults shown). Build-time params are baked into the
# graph at ingest; a re-index is needed to change them, but the demo can do
# that in-place via update_collection — no re-embed required.
HNSW_M=16
HNSW_EF_CONSTRUCT=100
SEARCH_HNSW_EF=128
